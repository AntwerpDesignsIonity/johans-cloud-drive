{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "ics-app/build",
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
